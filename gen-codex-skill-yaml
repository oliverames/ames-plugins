#!/usr/bin/env python3
"""gen-codex-skill-yaml: emit agents/openai.yaml for each Codex-relevant skill.

Reads each SKILL.md frontmatter under plugins/<plugin>/skills/<skill>/ and
writes a sensible default agents/openai.yaml. Only skills under plugins
included in the Codex marketplace (.agents/plugins/marketplace.json) are
processed; Claude-only plugins are excluded automatically.

The generated openai.yaml carries:
  - interface.display_name      (Title-Cased from SKILL.md `name`)
  - interface.short_description (first sentence of SKILL.md `description`)
  - interface.brand_color       (inherited from the plugin's .codex-plugin/plugin.json)
  - policy.allow_implicit_invocation = false
        ...when SKILL.md sets disable-model-invocation: true

Idempotent: existing openai.yaml files are skipped unless --force is set.
"""

import argparse
import json
import re
import sys
from pathlib import Path

HERE = Path(__file__).resolve().parent
PLUGINS_DIR = HERE / "plugins"
MARKETPLACE = HERE / ".agents" / "plugins" / "marketplace.json"

# Common abbreviations that should keep specific casing when converting
# kebab-case skill names to display names. Add new ones as skills are added.
ABBREVIATIONS = {
    "ai": "AI",
    "appkit": "AppKit",
    "bcbs": "BCBS",
    "claude": "Claude",
    "codex": "Codex",
    "gmcf": "GMCF",
    "ios": "iOS",
    "macos": "macOS",
    "mcp": "MCP",
    "mcps": "MCPs",
    "ocr": "OCR",
    "os": "OS",
    "pdf": "PDF",
    "ssh": "SSH",
    "swiftpm": "SwiftPM",
    "swiftui": "SwiftUI",
    "testflight": "TestFlight",
    "tmux": "tmux",
    "vdi": "VDI",
    "vt": "VT",
    "wwdc": "WWDC",
    "ynab": "YNAB",
    "1password": "1Password",
    "imagerelay": "ImageRelay",
}


def title_case(name):
    """Convert kebab-case to Title Case, honoring known abbreviations."""
    parts = []
    for token in name.split("-"):
        parts.append(ABBREVIATIONS.get(token.lower(), token.capitalize()))
    return " ".join(parts)


def parse_frontmatter(text):
    """Return a dict of the YAML-ish frontmatter at the top of SKILL.md.

    Hand-rolled because Python 3.9 has no built-in YAML parser and we want this
    script to work without external dependencies. Supports the field shapes our
    SKILL.md files actually use: scalar values, single-quoted, double-quoted,
    and folded (`>`/`>-`) or literal (`|`/`|-`) block scalars.
    """
    m = re.match(r"^---\s*\n(.*?)\n---", text, re.DOTALL)
    if not m:
        return None
    block = m.group(1)
    result = {}
    lines = block.split("\n")
    i = 0
    while i < len(lines):
        line = lines[i]
        if not line.strip():
            i += 1
            continue
        m2 = re.match(r"^([\w-]+)\s*:\s*(.*)$", line)
        if not m2:
            i += 1
            continue
        key = m2.group(1)
        rest = m2.group(2).strip()
        if rest in (">", "|", ">-", "|-", ">+", "|+"):
            # Multi-line block scalar; collect indented lines below
            buf = []
            indent = None
            i += 1
            while i < len(lines):
                if not lines[i].strip():
                    buf.append("")
                    i += 1
                    continue
                # Stop when we hit a non-indented line (new top-level key)
                stripped = lines[i].lstrip(" ")
                if stripped == lines[i] and lines[i].strip():
                    break
                if indent is None:
                    indent = len(lines[i]) - len(stripped)
                buf.append(lines[i][indent:].rstrip())
                i += 1
            # Fold paragraphs (collapse single newlines into spaces; preserve blank-line breaks)
            joined = " ".join(b for b in buf if b)
            result[key] = joined
        else:
            # Single-line value
            if (rest.startswith('"') and rest.endswith('"')) or (
                rest.startswith("'") and rest.endswith("'")
            ):
                rest = rest[1:-1]
            result[key] = rest
            i += 1
    return result


def first_sentence(text, max_chars=160):
    if not text:
        return ""
    text = " ".join(text.split())
    m = re.search(r"[.!?](?:\s|$)", text)
    sentence = text[: m.end()].strip() if m else text
    if len(sentence) > max_chars:
        sentence = sentence[: max_chars - 1].rstrip() + "…"
    return sentence


def yaml_quote(s):
    """Return a double-quoted YAML scalar with embedded quotes/backslashes escaped."""
    return '"' + s.replace("\\", "\\\\").replace('"', '\\"') + '"'


def emit_yaml(display_name, short_description, brand_color, allow_implicit):
    lines = ["# Generated by gen-codex-skill-yaml; safe to edit by hand.", "interface:"]
    lines.append(f"  display_name: {yaml_quote(display_name)}")
    if short_description:
        lines.append(f"  short_description: {yaml_quote(short_description)}")
    if brand_color:
        lines.append(f"  brand_color: {yaml_quote(brand_color)}")
    if not allow_implicit:
        lines.append("")
        lines.append("policy:")
        lines.append("  allow_implicit_invocation: false")
    return "\n".join(lines) + "\n"


def codex_plugin_names():
    if not MARKETPLACE.exists():
        sys.exit(f"error: {MARKETPLACE} not found; run ./sync first")
    data = json.loads(MARKETPLACE.read_text())
    return {p["name"] for p in data.get("plugins", [])}


def plugin_brand_color(plugin_name):
    plugin_json = PLUGINS_DIR / plugin_name / ".codex-plugin" / "plugin.json"
    if not plugin_json.exists():
        return None
    data = json.loads(plugin_json.read_text())
    return data.get("interface", {}).get("brandColor")


def main():
    parser = argparse.ArgumentParser(description=__doc__.split("\n")[0])
    parser.add_argument("--force", action="store_true", help="overwrite existing openai.yaml files")
    parser.add_argument("--dry-run", action="store_true", help="list what would be written without writing")
    args = parser.parse_args()

    eligible = codex_plugin_names()
    print(f"Eligible plugins ({len(eligible)}): {sorted(eligible)}")

    written = skipped = warnings = 0
    for plugin_dir in sorted(PLUGINS_DIR.iterdir()):
        if not plugin_dir.is_dir() or plugin_dir.name not in eligible:
            continue
        skills_dir = plugin_dir / "skills"
        if not skills_dir.is_dir():
            continue
        brand = plugin_brand_color(plugin_dir.name)
        for skill_dir in sorted(skills_dir.iterdir()):
            if not skill_dir.is_dir():
                continue
            skill_md = skill_dir / "SKILL.md"
            if not skill_md.exists():
                continue
            fm = parse_frontmatter(skill_md.read_text())
            if not fm or "name" not in fm:
                print(f"  WARN: missing or unparseable frontmatter at {skill_md}")
                warnings += 1
                continue

            display = title_case(fm["name"])
            short = first_sentence(fm.get("description", ""), max_chars=160)
            explicit_only = str(fm.get("disable-model-invocation", "")).strip().lower() == "true"
            allow = not explicit_only

            content = emit_yaml(display, short, brand, allow)
            target = skill_dir / "agents" / "openai.yaml"

            if target.exists() and not args.force:
                skipped += 1
                continue
            rel = target.relative_to(HERE)
            if args.dry_run:
                print(f"  WOULD write {rel}")
            else:
                target.parent.mkdir(parents=True, exist_ok=True)
                target.write_text(content)
                written += 1
                marker = " (explicit-only)" if explicit_only else ""
                print(f"  wrote {rel}{marker}")

    print(f"\nDone. Wrote {written}, skipped {skipped} existing, {warnings} warning(s).")


if __name__ == "__main__":
    main()
