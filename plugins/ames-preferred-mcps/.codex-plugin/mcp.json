{
  "mcpServers": {
    "apple-docs": {
      "command": "npx",
      "args": [
        "-y",
        "@kimsungwhee/apple-docs-mcp@latest"
      ]
    },
    "apple-notifier": {
      "command": "npx",
      "args": [
        "-y",
        "apple-notifier-mcp@latest"
      ]
    },
    "drafts": {
      "command": "npx",
      "args": [
        "-y",
        "@agiletortoise/drafts-mcp-server@latest"
      ]
    },
    "excel": {
      "command": "uvx",
      "args": [
        "excel-mcp-server",
        "stdio"
      ]
    },
    "google-workspace": {
      "command": "npx",
      "args": [
        "-y",
        "@aaronsb/google-workspace-mcp@latest"
      ],
      "env": {
        "GOOGLE_CLIENT_ID": "${GOOGLE_WORKSPACE_OAUTH_CLIENT_ID}",
        "GOOGLE_CLIENT_SECRET": "${GOOGLE_WORKSPACE_OAUTH_CLIENT_SECRET}"
      }
    },
    "macos-automator": {
      "command": "npx",
      "args": [
        "-y",
        "@steipete/macos-automator-mcp@latest"
      ]
    },
    "pandoc": {
      "command": "uvx",
      "args": [
        "mcp-pandoc"
      ]
    },
    "peekaboo": {
      "command": "npx",
      "args": [
        "-y",
        "@steipete/peekaboo@latest",
        "mcp"
      ]
    },
    "XcodeBuildMCP": {
      "command": "npx",
      "args": [
        "-y",
        "xcodebuildmcp@latest",
        "mcp"
      ]
    },
    "iMCP": {
      "command": "/Applications/iMCP.app/Contents/MacOS/imcp-server"
    },
    "SimGenie": {
      "command": "/Applications/Sim Genie.app/Contents/MacOS/simgenie-mcp"
    },
    "sosumi": {
      "type": "http",
      "url": "https://sosumi.ai/mcp"
    },
    "markitdown": {
      "command": "uvx",
      "args": [
        "markitdown-mcp"
      ]
    }
  }
}
