#!/usr/bin/env python3
"""sync: regenerate marketplace manifests from per-plugin plugin.json files.

Run before pushing to GitHub. Claude Code polls the marketplace manifest
and auto-updates installed plugins when versions change. Codex does the
same on its own schedule.

Handles both hosts:
  Claude Code: .claude-plugin/marketplace.json (authoritative source of truth)
  Codex: .agents/plugins/marketplace.json (regenerated, Codex plugin.json
      versions propagated from Claude side)

Usage:
    ./sync
    ./sync --check-codex
"""

import argparse
import json
import os
import subprocess
import sys
from pathlib import Path

# Terminal styling
_NO_COLOR = os.environ.get("NO_COLOR") is not None or not sys.stdout.isatty()
_B = "" if _NO_COLOR else "\033[38;5;141m"   # brand purple
_S = "" if _NO_COLOR else "\033[38;5;114m"   # success green
_W = "" if _NO_COLOR else "\033[38;5;214m"   # warn amber
_M = "" if _NO_COLOR else "\033[38;5;244m"   # muted gray
_R = "" if _NO_COLOR else "\033[0m"

def _success(msg): print(f"  {_S}\u2713{_R} {_S}{msg}{_R}")
def _warn(msg):    print(f"  {_W}!{_R} {_W}{msg}{_R}")
def _dim(msg):     print(f"  {_M}{msg}{_R}")
def _header(title, sub=""): print(f"\n{_B}{'-' * 48}{_R}\n{_B}  {title}{('  ' + sub) if sub else ''}{_R}\n{_B}{'-' * 48}{_R}\n")

HERE = Path(__file__).parent
PLUGINS_DIR = HERE / "plugins"
CLAUDE_MARKETPLACE = HERE / ".claude-plugin" / "marketplace.json"
CODEX_MARKETPLACE = HERE / ".agents" / "plugins" / "marketplace.json"


def read_json(path):
    """Load JSON from path, exiting with a readable error on parse failure."""
    try:
        with open(path) as f:
            return json.load(f)
    except json.JSONDecodeError as exc:
        sys.exit(f"error: invalid JSON in {path}: {exc}")

parser = argparse.ArgumentParser(description="Regenerate ames-plugins marketplace manifests")
parser.add_argument(
    "--check-codex",
    action="store_true",
    help="run the report-only Codex doctor after sync completes",
)
args = parser.parse_args()

_header("sync", "ames-plugins marketplaces")

# Read current Claude marketplace to preserve top-level metadata
claude_current = read_json(CLAUDE_MARKETPLACE)

# Pass 1: propagate Claude plugin.json versions into matching Codex plugin.json
# files so the two sides never drift. Claude side is authoritative. Also create
# Codex-native MCP manifests from Claude's flat .mcp.json files.
SHARED_CODEX_FIELDS = (
    "description",
    "author",
    "homepage",
    "repository",
    "license",
    "keywords",
    "category",
)

propagated = 0
codex_metadata_synced = 0
codex_mcp_wrapped = 0
for plugin_dir in sorted(PLUGINS_DIR.iterdir()):
    if not plugin_dir.is_dir():
        continue
    claude_json = plugin_dir / ".claude-plugin" / "plugin.json"
    codex_json = plugin_dir / ".codex-plugin" / "plugin.json"
    if not claude_json.exists() or not codex_json.exists():
        continue
    claude_meta = read_json(claude_json)
    codex_meta = read_json(codex_json)
    claude_version = claude_meta.get("version")
    codex_changed = False
    if codex_meta.get("version") != claude_version:
        codex_meta["version"] = claude_version
        codex_changed = True
        _dim(f"propagated version {claude_version} to {plugin_dir.name}/.codex-plugin/plugin.json")
        propagated += 1
    for field in SHARED_CODEX_FIELDS:
        if field in claude_meta and codex_meta.get(field) != claude_meta[field]:
            codex_meta[field] = claude_meta[field]
            codex_changed = True
            codex_metadata_synced += 1
    claude_mcp = plugin_dir / ".mcp.json"
    codex_mcp = plugin_dir / ".codex-plugin" / "mcp.json"
    if claude_mcp.exists():
        mcp_data = read_json(claude_mcp)
        if isinstance(mcp_data, dict) and "mcpServers" in mcp_data:
            sys.exit(
                f"error: {claude_mcp} contains a top-level 'mcpServers' wrapper. "
                "Claude Code .mcp.json must be flat (no outer mcpServers key). "
                "See CLAUDE.md 'Plugin conventions'."
            )
        codex_mcp_data = {"mcpServers": mcp_data}
        codex_mcp.parent.mkdir(parents=True, exist_ok=True)
        current_codex_mcp = None
        if codex_mcp.exists():
            current_codex_mcp = read_json(codex_mcp)
        if current_codex_mcp != codex_mcp_data:
            with open(codex_mcp, "w") as f:
                json.dump(codex_mcp_data, f, indent=2)
                f.write("\n")
            _dim(f"wrapped {plugin_dir.name}/.mcp.json for Codex at .codex-plugin/mcp.json")
            codex_mcp_wrapped += 1
        if codex_meta.get("mcpServers") != "./.codex-plugin/mcp.json":
            codex_meta["mcpServers"] = "./.codex-plugin/mcp.json"
            codex_changed = True
    if codex_changed:
        with open(codex_json, "w") as f:
            json.dump(codex_meta, f, indent=2)
            f.write("\n")

# Pass 2: regenerate Claude marketplace.json from per-plugin .claude-plugin/plugin.json
# Optional plugin.json fields (author, homepage, repository, license, keywords,
# category) propagate into the marketplace entry when present, so plugin.json
# remains the single source of truth for metadata.
OPTIONAL_PROPAGATED = (
    "author",
    "homepage",
    "repository",
    "license",
    "keywords",
    "category",
)
claude_plugins = []
for plugin_dir in sorted(PLUGINS_DIR.iterdir()):
    if not plugin_dir.is_dir():
        continue
    plugin_json = plugin_dir / ".claude-plugin" / "plugin.json"
    if not plugin_json.exists():
        continue
    meta = read_json(plugin_json)
    entry = {
        "name": meta["name"],
        "version": meta["version"],
        "description": meta.get("description", ""),
        "source": f"./plugins/{plugin_dir.name}",
        "strict": True,
    }
    for field in OPTIONAL_PROPAGATED:
        if field in meta:
            entry[field] = meta[field]
    claude_plugins.append(entry)

for required_key in ("name", "owner", "metadata"):
    if required_key not in claude_current:
        sys.exit(f"error: {CLAUDE_MARKETPLACE} is missing required top-level key '{required_key}'")
claude_output = {
    "name": claude_current["name"],
    "owner": claude_current["owner"],
    "metadata": claude_current["metadata"],
    "plugins": claude_plugins,
}
with open(CLAUDE_MARKETPLACE, "w") as f:
    json.dump(claude_output, f, indent=2)
    f.write("\n")
_success(f".claude-plugin/marketplace.json: {len(claude_plugins)} plugin(s)")
for p in claude_plugins:
    print(f"  {_M}.{_R} {p['name']} {_M}v{p['version']}{_R}")

# Pass 3: regenerate Codex marketplace.json from per-plugin .codex-plugin/plugin.json
# Plugins without a .codex-plugin/ directory are Claude-only
# (e.g. build-ios-apps-codex, build-macos-apps-codex) and are correctly
# excluded from the Codex manifest.
if CODEX_MARKETPLACE.exists():
    codex_current = read_json(CODEX_MARKETPLACE)
    codex_plugins = []
    for plugin_dir in sorted(PLUGINS_DIR.iterdir()):
        if not plugin_dir.is_dir():
            continue
        codex_json = plugin_dir / ".codex-plugin" / "plugin.json"
        if not codex_json.exists():
            continue
        meta = read_json(codex_json)
        entry = {
            "name": meta["name"],
            "version": meta.get("version"),
            "source": {
                "source": "local",
                "path": f"./plugins/{plugin_dir.name}",
            },
            "policy": {
                "installation": "AVAILABLE",
                "authentication": "ON_INSTALL",
            },
            "category": meta.get("category", "productivity"),
        }
        codex_plugins.append(entry)
    # Keep marketplace-level metadata in lockstep across hosts. Claude remains
    # the authoring source of truth, but Codex should advertise the same release.
    codex_metadata = claude_current.get("metadata") or codex_current.get("metadata", {})
    codex_output = {
        "name": codex_current["name"],
        "interface": codex_current.get("interface", {"displayName": codex_current["name"]}),
        "metadata": codex_metadata,
        "plugins": codex_plugins,
    }
    with open(CODEX_MARKETPLACE, "w") as f:
        json.dump(codex_output, f, indent=2)
        f.write("\n")
    _success(f".agents/plugins/marketplace.json: {len(codex_plugins)} plugin(s)")
    if propagated:
        _dim(f"propagated {propagated} Claude-to-Codex version(s)")
    if codex_metadata_synced:
        _dim(f"synced {codex_metadata_synced} Codex metadata field(s)")
    if codex_mcp_wrapped:
        _dim(f"updated {codex_mcp_wrapped} Codex MCP manifest(s)")
else:
    _warn(".agents/plugins/marketplace.json not present; Codex side skipped")

if args.check_codex:
    doctor = HERE / "codex-doctor"
    if doctor.exists():
        print()
        sys.stdout.flush()
        result = subprocess.run([sys.executable, str(doctor), "--no-live"], cwd=str(HERE), check=False)
        if result.returncode != 0:
            sys.exit(result.returncode)
    else:
        _warn("codex-doctor not found; Codex check skipped")

print()
