#!/usr/bin/env bash
# bump-and-sync — Bump a plugin version and push marketplace update.
#
# Bumps the patch version of the specified plugin, regenerates marketplace.json
# via ./sync, and pushes — triggering Claude Code auto-update.
#
# Usage:
#   ./bump-and-sync <plugin-name>
#
# Examples:
#   ./bump-and-sync ames-preferred-mcps
#   ./bump-and-sync ames-standalone-skills

set -e

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/style.sh" 2>/dev/null || {
    success() { echo "  ✓ $1"; }
    error()   { echo "  ✗ $1"; }
    warn()    { echo "  ! $1"; }
    step()    { echo "  → $1"; }
    header()  { echo ""; echo "=== ${1}${2:+ — $2} ==="; echo ""; }
    banner()  { echo ""; echo "[ $1 ]"; echo ""; }
}

MARKETPLACE="$SCRIPT_DIR"

PLUGIN="${1:-}"
if [ -z "$PLUGIN" ]; then
    error "missing plugin name"
    echo
    echo "Usage: ./bump-and-sync <plugin-name>"
    echo
    echo "Available plugins:"
    find "$MARKETPLACE/plugins" -mindepth 2 -maxdepth 2 -path "*/.claude-plugin" -print |
        sed "s#^$MARKETPLACE/plugins/##; s#/.claude-plugin\$##" |
        sort |
        sed 's/^/  - /'
    exit 2
fi

PLUGIN_JSON="$MARKETPLACE/plugins/$PLUGIN/.claude-plugin/plugin.json"

header "bump-and-sync" "$PLUGIN"

if [ ! -f "$PLUGIN_JSON" ]; then
    error "plugin.json not found at $PLUGIN_JSON"
    exit 1
fi

# Bump patch version and capture the new value
NEW_VERSION=$(python3 -c "
import json, pathlib, sys
p = pathlib.Path(sys.argv[1])
d = json.loads(p.read_text())
parts = d['version'].split('.')
parts[-1] = str(int(parts[-1]) + 1)
d['version'] = '.'.join(parts)
p.write_text(json.dumps(d, indent=2) + '\n')
print(d['version'])
" "$PLUGIN_JSON")

success "$PLUGIN → v$NEW_VERSION"

# Regenerate marketplace.json
step "Syncing marketplace..."
cd "$MARKETPLACE"
python3 sync --check-codex

# Commit and push if there are changes
git add "plugins/$PLUGIN/.claude-plugin/plugin.json" .claude-plugin/marketplace.json
# Also stage the Codex side, which sync just brought in-sync (if the plugin has a Codex manifest)
[ -f "plugins/$PLUGIN/.codex-plugin/plugin.json" ] && git add "plugins/$PLUGIN/.codex-plugin/plugin.json"
[ -f "plugins/$PLUGIN/.codex-plugin/mcp.json" ] && git add "plugins/$PLUGIN/.codex-plugin/mcp.json"
[ -f .agents/plugins/marketplace.json ] && git add .agents/plugins/marketplace.json
if git diff --cached --quiet; then
    step "Nothing changed, skipping commit"
    exit 0
fi

git commit -m "sync: $PLUGIN $NEW_VERSION" >/dev/null
if git push 2>/dev/null; then
    banner "Marketplace updated — Claude Code will auto-update on next startup"
else
    warn "Committed locally, push failed"
fi
